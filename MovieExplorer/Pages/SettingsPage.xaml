<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieExplorer.Pages.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="15" Spacing="15">

        <Label Text="Settings" FontSize="24" Margin="0,0,0,10"/>

        <!-- Dark Mode Toggle -->
        <Border Padding="10" Stroke="Gray">
            <HorizontalStackLayout>
                <Label Text="Dark Mode" VerticalOptions="Center" WidthRequest="150"/>
                <Switch x:Name="DarkModeSwitch" Toggled="DarkModeSwitch_Toggled"/>
            </HorizontalStackLayout>
        </Border>

        <!-- Change Name -->
        <Border Padding="10" Stroke="Gray">
            <VerticalStackLayout>
                <Label Text="Your Name"/>
                <HorizontalStackLayout Spacing="10">
                    <Entry x:Name="NameEntry" WidthRequest="200" Placeholder="Enter name"/>
                    <Button Text="Save" Clicked="SaveNameButton_Clicked"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Reset Data -->
        <Button Text="Reset All Data" 
            BackgroundColor="Red" 
            TextColor="White"
            Clicked="ResetButton_Clicked"
            Margin="0,20,0,0"/>
    </VerticalStackLayout>


</ContentPage>