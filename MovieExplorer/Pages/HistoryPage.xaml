<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieExplorer.Pages.HistoryPage"
             Title="View History">
    <!--=Pasted in and edited from FavouritesPage=-->
    <Grid RowDefinitions="Auto,Auto,*" Padding="10">

        <Label Text="Movies You've Looked At" 
           FontSize="22" 
           Grid.Row="0"
           Margin="0,0,0,10"/>

        <Button x:Name="ClearButton" 
            Text="Clear History" 
            Grid.Row="1"
            Clicked="ClearButton_Clicked"
            Margin="0,0,0,10"/>

        <CollectionView x:Name="HistoryList" Grid.Row="2">
            <CollectionView.EmptyView>
                <Label Text="You have no watched movies yet ¯\_(ツ)_/¯. Go watch some!"
                   FontSize="16"
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"/>
            </CollectionView.EmptyView>
            
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Padding="10" Stroke="LightGray" StrokeThickness="1">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="{Binding Emoji}" 
                               FontSize="35" 
                               VerticalOptions="Center"
                               Grid.Column="0"/>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0">
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Year}" FontSize="14"/>
                                <Label Text="{Binding GenreString}" TextColor="Gray" FontSize="12"/>
                                <Label Text="{Binding ViewedDate, StringFormat='Viewed: {0:dd/MM/yyyy HH:mm}'}" 
                                   TextColor="Blue" FontSize="11"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>