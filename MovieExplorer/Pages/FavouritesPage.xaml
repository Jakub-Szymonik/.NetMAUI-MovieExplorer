<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieExplorer.Pages.FavouritesPage"
             Title="Favourites">
    <Grid RowDefinitions="Auto,*" Padding="10">

        <Label Text="Your Favourite Movies" 
           FontSize="22" 
           Grid.Row="0"
           Margin="0,0,0,10"/>

        <CollectionView x:Name="FavouritesList" 
                    Grid.Row="1"
                    SelectionMode="Single"
                    SelectionChanged="FavouritesList_SelectionChanged">
            <CollectionView.EmptyView>
                <Label Text="No favourites yet. Go browse some movies!" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="5" Padding="10" Stroke="Gray" StrokeThickness="1">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="{Binding Emoji}" 
                               FontSize="40" 
                               VerticalOptions="Center"
                               Grid.Column="0"/>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0">
                                <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold"/>
                                <Label Text="{Binding Year}"/>
                                <Label Text="{Binding GenreString}" TextColor="Gray"/>
                                <Label Text="{Binding AddedDate, StringFormat='Added: {0:dd/MM/yyyy HH:mm}'}" 
                                   TextColor="Green" FontSize="12"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>